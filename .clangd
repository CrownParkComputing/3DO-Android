# Point clangd at the NDK compilation database so it resolves the Android
# sysroot headers (<android/log.h>, etc). Without this, clangd analyses the
# native sources with no --sysroot and reports false "file not found" /
# "unknown type" errors even though the gradle CMake/NDK build is clean.
#
# This uses the stable (non-hashed) per-ABI database under .cxx/tools; it is
# regenerated by gradle on configure. Editor-only — does not affect the build.
CompileFlags:
  CompilationDatabase: app/.cxx/tools/debug/arm64-v8a
