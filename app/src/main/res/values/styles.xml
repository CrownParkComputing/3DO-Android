<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Splash screen theme -->
    <style name="SplashTheme" parent="AppTheme">
        <item name="android:windowBackground">@drawable/splash_image</item>
    </style>

    <!-- Ymir-styled dark theme for the MainActivity launcher (accent #2E7D5B, chrome #101214).
         Parent must be AppCompat because MainActivity extends AppCompatActivity. -->
    <style name="HomeTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:colorAccent">#2E7D5B</item>
        <item name="android:colorPrimary">#101214</item>
        <item name="android:colorPrimaryDark">#101214</item>
        <item name="android:navigationBarColor">#101214</item>
        <item name="android:statusBarColor">#101214</item>
        <item name="android:windowBackground">#101214</item>
    </style>
</resources>