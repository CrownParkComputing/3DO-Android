<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e"
    tools:context=".SettingsActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="#252547">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Left Column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="8dp"
                android:paddingStart="0dp">

                <!-- BIOS Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BIOS Configuration"
                    android:textColor="#4488FF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/bios_path_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/bios_not_set"
                    android:textColor="#AAAAAA"
                    android:padding="12dp"
                    android:background="#252547"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/select_bios_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/select_bios"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4488FF"
                    android:layout_marginBottom="24dp" />

                <!-- Library Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Game Library"
                    android:textColor="#4488FF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/library_path_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/library_not_set"
                    android:textColor="#AAAAAA"
                    android:padding="12dp"
                    android:background="#252547"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/select_library_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/select_library"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4488FF"
                    android:layout_marginBottom="24dp" />

                <!-- Vulkan Driver Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/vulkan_driver"
                    android:textColor="#4488FF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/vulkan_driver_path_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/vulkan_driver_system"
                    android:textColor="#AAAAAA"
                    android:padding="12dp"
                    android:background="#252547"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/select_vulkan_driver_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/vulkan_driver_select"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4488FF"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/reset_vulkan_driver_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/vulkan_driver_reset"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#666666"
                    android:layout_marginBottom="24dp" />

            </LinearLayout>

            <!-- Right Column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="0dp">

                <!-- Display Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Display &amp; Emulation"
                    android:textColor="#4488FF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Renderer"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/renderer_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#252547"
                    android:padding="8dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Texture Filtering"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/filtering_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#252547"
                    android:padding="8dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Console Region"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/region_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#252547"
                    android:padding="8dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Library View Style"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/view_style_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#252547"
                    android:padding="8dp"
                    android:layout_marginBottom="12dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/crt_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="@string/crt_filter"
                    android:textColor="#FFFFFF"
                    android:thumbTint="#4488FF"
                    android:trackTint="#252547" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/bezel_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Enable Bezel"
                    android:textColor="#FFFFFF"
                    android:thumbTint="#4488FF"
                    android:trackTint="#252547" />

                <Button
                    android:id="@+id/download_bezels_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Download Bezels from GitHub"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4488FF"
                    android:layout_marginBottom="12dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/debug_overlay_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="Debug Overlay"
                    android:textColor="#FFFFFF"
                    android:thumbTint="#4488FF"
                    android:trackTint="#252547" />

                <!-- Controller Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Input"
                    android:textColor="#4488FF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/controller_mapper_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎮 Configure Controller"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#666666"
                    android:layout_marginBottom="24dp" />

                <!-- Data Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maintenance"
                    android:textColor="#4488FF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/clear_cache_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Clear Cache"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#AA4444"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/view_logs_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View Logs"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#666666"
                    android:layout_marginBottom="24dp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Button -->
    <Button
        android:id="@+id/back_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/back"
        android:textColor="#FFFFFF"
        android:backgroundTint="#333366" />

</LinearLayout>
