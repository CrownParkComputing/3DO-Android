<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EmulatorActivity">

    <!-- Emulator surface fills the entire screen -->
    <FrameLayout
        android:id="@+id/emulator_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000" />

    <!-- Semi-transparent overlay menu (hidden by default) -->
    <LinearLayout
        android:id="@+id/overlay_menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="#CC222222"
        android:padding="24dp"
        android:elevation="8dp"
        android:visibility="gone">

        <Button
            android:id="@+id/pause_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/pause"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF4444"
            android:textSize="16sp" />

        <Button
            android:id="@+id/reset_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/reset"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF8800"
            android:textSize="16sp" />

        <Button
            android:id="@+id/load_cd_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/load_cd"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4488FF"
            android:textSize="16sp" />

        <Button
            android:id="@+id/controller_map_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/controller_map"
            android:textColor="#FFFFFF"
            android:backgroundTint="#44AA44"
            android:textSize="16sp" />

        <Button
            android:id="@+id/back_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="@string/exit"
            android:textColor="#FFFFFF"
            android:backgroundTint="#888888"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Top Left: FPS Counter -->
    <TextView
        android:id="@+id/fps_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:text="FPS: --"
        android:textColor="#00FF00"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:background="#88000000"
        android:padding="4dp"
        android:elevation="4dp" />

    <!-- Top Right: Quick settings toolbar with labels -->
    <LinearLayout
        android:id="@+id/quick_toolbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical"
        android:background="#88000000"
        android:padding="8dp"
        android:elevation="4dp"
        android:visibility="visible">

        <!-- CD Button with label -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💿"
                android:textSize="20sp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/cd_button"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Load CD"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4488FF"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />
        </LinearLayout>

        <!-- Aspect Ratio Button -->
        <Button
            android:id="@+id/aspect_ratio_button"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginBottom="4dp"
            android:text="4:3"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#44DD44" />

        <!-- Renderer Button -->
        <Button
            android:id="@+id/renderer_button"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginBottom="4dp"
            android:text="OpenGL"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#AA44FF" />

        <!-- Filtering Button -->
        <Button
            android:id="@+id/filtering_button"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:text="Smooth"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFAA44" />

    </LinearLayout>

    <!-- Bottom Left: Menu hamburger button -->
    <ImageButton
        android:id="@+id/menu_toggle_button"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="16dp"
        android:src="@android:drawable/ic_menu_more"
        android:contentDescription="Menu"
        android:background="#66000000"
        android:scaleType="centerInside"
        android:padding="12dp"
        app:tint="#FFFFFF"
        android:elevation="4dp" />

    <!-- Status indicator for current settings -->
    <TextView
        android:id="@+id/status_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="20dp"
        android:layout_marginEnd="16dp"
        android:text="4:3 | OpenGL | Linear"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:background="#66000000"
        android:padding="4dp"
        android:visibility="visible" />

</FrameLayout>