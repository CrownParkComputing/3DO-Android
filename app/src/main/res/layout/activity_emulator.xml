<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EmulatorActivity">

    <!-- Emulator surface fills the entire screen -->
    <FrameLayout
        android:id="@+id/emulator_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000" />

    <!-- Semi-transparent overlay menu (hidden by default) -->
    <LinearLayout
        android:id="@+id/overlay_menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="#CC222222"
        android:padding="24dp"
        android:elevation="8dp"
        android:visibility="gone">

        <Button
            android:id="@+id/pause_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/pause"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF4444"
            android:textSize="16sp" />

        <Button
            android:id="@+id/reset_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/reset"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF8800"
            android:textSize="16sp" />

        <Button
            android:id="@+id/load_cd_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/load_cd"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4488FF"
            android:textSize="16sp" />

        <Button
            android:id="@+id/controller_map_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/controller_map"
            android:textColor="#FFFFFF"
            android:backgroundTint="#44AA44"
            android:textSize="16sp" />

        <Button
            android:id="@+id/back_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="@string/exit"
            android:textColor="#FFFFFF"
            android:backgroundTint="#888888"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Small toggle button in top-right corner -->
    <Button
        android:id="@+id/menu_toggle_button"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|right"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:text="\u2630"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:background="#66000000"
        android:elevation="4dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp" />

</FrameLayout>
