<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EmulatorActivity">

    <!-- Emulator surface fills the entire screen -->
    <FrameLayout
        android:id="@+id/emulator_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000" />

    <ImageView
        android:id="@+id/emulator_bezel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="false"
        android:clickable="false"
        android:contentDescription="@null"
        android:focusable="false"
        android:scaleType="fitXY"
        android:src="@drawable/emulator_bezel" />

    <!-- Top Left: FPS Counter - compact icon style -->
    <TextView
        android:id="@+id/fps_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:text="FPS 0"
        android:textColor="#00FF00"
        android:textSize="18sp"
        android:background="#88000000"
        android:padding="6dp"
        android:elevation="4dp"
        android:visibility="gone" />

    <!-- Native to 8K option in graphics options menu -->
    <!-- This will be handled in the render options dialog, no need for a separate button here -->

    <ImageButton
        android:id="@+id/pause_button"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="16dp"
        android:background="#66000000"
        android:contentDescription="@string/pause"
        android:elevation="4dp"
        android:padding="12dp"
        android:src="@android:drawable/ic_media_pause"
        app:tint="#FFFFFF" />

    <ImageButton
        android:id="@+id/controller_map_button"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"
        android:background="#66000000"
        android:contentDescription="@string/controller_map"
        android:elevation="4dp"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_manage"
        app:tint="#FFFFFF" />

    <!-- Status indicator for current settings -->
    <TextView
        android:id="@+id/status_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="20dp"
        android:layout_marginEnd="16dp"
        android:text="4:3 | OpenGL | Linear"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="#66000000"
        android:padding="6dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Loading game..."
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

    </LinearLayout>

</FrameLayout>