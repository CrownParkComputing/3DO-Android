<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".EmulatorActivity">

    <!-- Bezel in the background -->
    <ImageView
        android:id="@+id/emulator_bezel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:adjustViewBounds="false"
        android:clickable="false"
        android:contentDescription="@null"
        android:focusable="false"
        android:scaleType="fitXY"
        android:src="@drawable/bezel_fz10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Guidelines for the TV screen area defined in 3do.info (1920x1080 base) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/screen_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.125" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/screen_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.875" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/screen_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.0" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/screen_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="1.0" />

    <!-- Emulator surface on top, constrained to the TV screen area -->
    <FrameLayout
        android:id="@+id/emulator_surface"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintStart_toStartOf="@id/screen_left"
        app:layout_constraintEnd_toEndOf="@id/screen_right"
        app:layout_constraintTop_toTopOf="@id/screen_top"
        app:layout_constraintBottom_toBottomOf="@id/screen_bottom" />

    <!-- Top Left: FPS Counter -->
    <TextView
        android:id="@+id/fps_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:text="FPS 0"
        android:textColor="#00FF00"
        android:textSize="18sp"
        android:background="#88000000"
        android:padding="6dp"
        android:elevation="4dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/pause_button"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="16dp"
        android:background="#66000000"
        android:contentDescription="@string/pause"
        android:elevation="4dp"
        android:padding="12dp"
        android:src="@android:drawable/ic_media_pause"
        app:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:visibility="gone" />

    <ImageButton
        android:id="@+id/quick_settings_button"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"
        android:background="#66000000"
        android:contentDescription="Settings"
        android:elevation="4dp"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_manage"
        app:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/play_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="#AA181B1F"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/top_renderer_button"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minWidth="64dp"
            android:minHeight="32dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="Vulkan"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/top_aspect_button"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:minWidth="64dp"
            android:minHeight="32dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="4:3"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/top_crt_button"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:minWidth="64dp"
            android:minHeight="32dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="No CRT"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/top_library_button"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:minWidth="64dp"
            android:minHeight="32dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="Library"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/top_settings_button"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:minWidth="48dp"
            android:minHeight="32dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="Settings"
            android:textAllCaps="false"
            android:textSize="12sp" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/settings_panel"
        android:layout_width="360dp"
        android:layout_height="0dp"
        android:background="#EE181B1F"
        android:fillViewport="false"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="4DO Settings"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/side_close_button"
                    android:layout_width="48dp"
                    android:layout_height="32dp"
                    android:minWidth="48dp"
                    android:minHeight="32dp"
                    android:text="X"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

            </LinearLayout>

            <Button
                android:id="@+id/side_library_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Game Library"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/side_renderer_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="Renderer"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/side_aspect_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="Aspect"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/side_filter_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="Texture Filter"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/side_bezel_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="Bezel"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/side_crt_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="CRT"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/side_controller_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="Controller Mapping"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/side_full_settings_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="Storage and Setup"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/side_reset_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="Reset / Boot BIOS"
                android:textAllCaps="false" />

            <TextView
                android:id="@+id/side_status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="#E8EAED"
                android:textSize="12sp" />

        </LinearLayout>

    </ScrollView>

    <!-- Status indicator for current settings -->
    <TextView
        android:id="@+id/status_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:layout_marginEnd="16dp"
        android:text="4:3 | Vulkan | Linear"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="#66000000"
        android:padding="6dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Loading game..."
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
