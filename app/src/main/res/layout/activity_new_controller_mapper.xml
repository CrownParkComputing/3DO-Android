<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#060606"
    tools:context=".NewControllerMapperActivity">

    <TextView
        android:id="@+id/controller_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:gravity="center"
        android:text="3DO Controller Mapper"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/mapper_status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Tap a button below, then press a controller button to map it."
        android:textColor="#C8D0DB"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp">

        <!-- Left: shoulders + D-pad -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <Button
                    android:id="@+id/button_l1"
                    android:layout_width="92dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/mapper_button_background"
                    android:backgroundTint="#5E35B1"
                    android:text="L1"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/button_r1"
                    android:layout_width="92dp"
                    android:layout_height="52dp"
                    android:background="@drawable/mapper_button_background"
                    android:backgroundTint="#5E35B1"
                    android:text="R1"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <Button
                android:id="@+id/button_dpad_up"
                android:layout_width="84dp"
                android:layout_height="48dp"
                android:background="@drawable/mapper_button_background"
                android:backgroundTint="#546E7A"
                android:text="UP"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp">

                <Button
                    android:id="@+id/button_dpad_left"
                    android:layout_width="84dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/mapper_button_background"
                    android:backgroundTint="#546E7A"
                    android:text="LEFT"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/button_dpad_right"
                    android:layout_width="84dp"
                    android:layout_height="48dp"
                    android:background="@drawable/mapper_button_background"
                    android:backgroundTint="#546E7A"
                    android:text="RIGHT"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <Button
                android:id="@+id/button_dpad_down"
                android:layout_width="84dp"
                android:layout_height="48dp"
                android:background="@drawable/mapper_button_background"
                android:backgroundTint="#546E7A"
                android:text="DOWN"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Right: face buttons + media -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/button_a"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/mapper_button_background"
                    android:backgroundTint="#43A047"
                    android:text="A"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/button_b"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/mapper_button_background"
                    android:backgroundTint="#E53935"
                    android:text="B"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/button_c"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/mapper_button_background"
                    android:backgroundTint="#1E88E5"
                    android:text="C"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_play_pause"
                    android:layout_width="100dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/mapper_button_background"
                    android:backgroundTint="#00897B"
                    android:text="PLAY"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/button_stop"
                    android:layout_width="100dp"
                    android:layout_height="48dp"
                    android:background="@drawable/mapper_button_background"
                    android:backgroundTint="#FB8C00"
                    android:text="STOP"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/back_button"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="10dp"
        android:background="@drawable/mapper_button_background"
        android:text="@string/back"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textAllCaps="false" />

</LinearLayout>
