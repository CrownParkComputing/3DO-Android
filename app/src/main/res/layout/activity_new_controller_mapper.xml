<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#060606"
    tools:context=".NewControllerMapperActivity">

    <TextView
        android:id="@+id/controller_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp"
        android:gravity="center"
        android:text="3DO Controller Mapper"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/mapper_status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Tap a control on the 3DO pad image to remap it."
        android:textColor="#C8D0DB"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp">

        <ImageView
            android:id="@+id/controller_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@drawable/controller_3do"
            android:contentDescription="3DO Controller" />

        <Button
            android:id="@+id/button_dpad_up"
            android:layout_width="62dp"
            android:layout_height="42dp"
            android:layout_alignParentStart="true"
            android:layout_marginStart="156dp"
            android:layout_marginTop="98dp"
            android:background="@drawable/mapper_button_background"
            android:padding="4dp"
            android:text="UP"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <Button
            android:id="@+id/button_dpad_left"
            android:layout_width="62dp"
            android:layout_height="42dp"
            android:layout_alignParentStart="true"
            android:layout_marginStart="98dp"
            android:layout_marginTop="140dp"
            android:background="@drawable/mapper_button_background"
            android:padding="4dp"
            android:text="LEFT"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <Button
            android:id="@+id/button_dpad_right"
            android:layout_width="62dp"
            android:layout_height="42dp"
            android:layout_alignParentStart="true"
            android:layout_marginStart="214dp"
            android:layout_marginTop="140dp"
            android:background="@drawable/mapper_button_background"
            android:padding="4dp"
            android:text="RIGHT"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <Button
            android:id="@+id/button_dpad_down"
            android:layout_width="62dp"
            android:layout_height="42dp"
            android:layout_alignParentStart="true"
            android:layout_marginStart="156dp"
            android:layout_marginTop="182dp"
            android:background="@drawable/mapper_button_background"
            android:padding="4dp"
            android:text="DOWN"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <Button
            android:id="@+id/button_l1"
            android:layout_width="56dp"
            android:layout_height="36dp"
            android:layout_alignParentStart="true"
            android:layout_marginStart="118dp"
            android:layout_marginTop="26dp"
            android:background="@drawable/mapper_button_background"
            android:padding="4dp"
            android:text="L1"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <Button
            android:id="@+id/button_r1"
            android:layout_width="56dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="118dp"
            android:layout_marginTop="26dp"
            android:background="@drawable/mapper_button_background"
            android:padding="4dp"
            android:text="R1"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="126dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_stop"
                android:layout_width="46dp"
                android:layout_height="32dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/mapper_button_background"
                android:padding="3dp"
                android:text="X"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <Button
                android:id="@+id/button_play_pause"
                android:layout_width="46dp"
                android:layout_height="32dp"
                android:background="@drawable/mapper_button_background"
                android:padding="3dp"
                android:text="P"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

        </LinearLayout>

        <Button
            android:id="@+id/button_a"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="238dp"
            android:layout_marginTop="178dp"
            android:background="@drawable/mapper_button_background"
            android:padding="6dp"
            android:text="A"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/button_b"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="164dp"
            android:layout_marginTop="120dp"
            android:background="@drawable/mapper_button_background"
            android:padding="6dp"
            android:text="B"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/button_c"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="94dp"
            android:layout_marginTop="90dp"
            android:background="@drawable/mapper_button_background"
            android:padding="6dp"
            android:text="C"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

    </RelativeLayout>

    <Button
        android:id="@+id/back_button"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="10dp"
        android:background="@drawable/mapper_button_background"
        android:text="@string/back"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textAllCaps="false" />

</LinearLayout>